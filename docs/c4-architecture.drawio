        </mxCell>

        <mxCell id="comp-controller" value="&lt;b&gt;AuthController&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Component: REST Controller]&lt;/i&gt;&lt;br&gt;&lt;br&gt;POST /login&lt;br&gt;POST /refresh&lt;br&gt;POST /validate&lt;br&gt;DELETE /logout" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-web">
