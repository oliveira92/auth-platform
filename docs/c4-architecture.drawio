          <mxGeometry x="100" y="300" width="220" height="150" as="geometry" />
        </mxCell>

        <!-- Authorization Service -->
        <mxCell id="container-authz" value="&lt;b&gt;Authorization Service&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Spring Boot]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Gerenciamento RBAC.&lt;br&gt;Registro de aplicações.&lt;br&gt;Verificação de permissões.&lt;br&gt;Porta: 8082" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#006EAF;fontSize=10;" vertex="1" parent="boundary">
          <mxGeometry x="560" y="300" width="220" height="150" as="geometry" />
        </mxCell>

        <!-- Eureka Server -->
