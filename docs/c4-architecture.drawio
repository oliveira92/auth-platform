        <!-- API Gateway -->
        <mxCell id="container-gw" value="&lt;b&gt;API Gateway&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Container: Spring Cloud Gateway]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Ponto de entrada único.&lt;br&gt;Validação JWT, roteamento&lt;br&gt;e propagação de identidade.&lt;br&gt;Porta: 8080" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#006EAF;fontSize=10;" vertex="1" parent="boundary">
