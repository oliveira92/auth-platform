          <mxGeometry x="660" y="60" width="420" height="580" as="geometry" />
        </mxCell>

        <mxCell id="comp-ldap" value="&lt;b&gt;LdapUserAdapter&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Adapter: out]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Spring LDAP Template&lt;br&gt;Autenticação BIND + busca&lt;br&gt;de usuário e grupos" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-infra">
          <mxGeometry x="20" y="50" width="180" height="120" as="geometry" />
        </mxCell>

        <mxCell id="comp-jwt" value="&lt;b&gt;JwtTokenAdapter&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Adapter: out]&lt;/i&gt;&lt;br&gt;&lt;br&gt;JJWT RS256&lt;br&gt;Geração e parsing&lt;br&gt;de tokens JWT" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-infra">
          <mxGeometry x="220" y="50" width="180" height="120" as="geometry" />
        </mxCell>

        <mxCell id="comp-redis-adapter" value="&lt;b&gt;RedisTokenStorage&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Adapter: out]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Redis Template&lt;br&gt;TTL automático&lt;br&gt;Blacklist revogados" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-infra">
          <mxGeometry x="20" y="200" width="180" height="120" as="geometry" />
        </mxCell>

        <mxCell id="comp-aws-adapter" value="&lt;b&gt;AwsSecretsLoader&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Adapter: out]&lt;/i&gt;&lt;br&gt;&lt;br&gt;AWS SDK v2&lt;br&gt;Chaves RSA e credenciais&lt;br&gt;LDAP do Secrets Manager" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-infra">
          <mxGeometry x="220" y="200" width="180" height="120" as="geometry" />
        </mxCell>

        <mxCell id="comp-domain-svc" value="&lt;b&gt;AuthenticationDomainService&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Domain Service]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Cria Token domain objects&lt;br&gt;com UUID e tempo de vida" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=10;" vertex="1" parent="layer-infra">
          <mxGeometry x="120" y="360" width="180" height="100" as="geometry" />
        </mxCell>

        <!-- External systems at the right -->
        <mxCell id="ext3-ldap" value="LDAP/AD" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#999999;fontColor=#ffffff;strokeColor=#6B6B6B;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1360" y="180" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ext3-redis" value="Redis" style="shape=cylinder3;size=10;whiteSpace=wrap;html=1;fillColor=#438DD5;fontColor=#ffffff;strokeColor=#006EAF;fontSize=10;" vertex="1" parent="1">
