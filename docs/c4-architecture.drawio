          <mxGeometry x="340" y="60" width="300" height="500" as="geometry" />
        </mxCell>

        <mxCell id="comp-authn" value="&lt;b&gt;AuthenticateUser&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Use Case]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Autentica via LDAP e&lt;br&gt;emite par de tokens JWT" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-app">
          <mxGeometry x="20" y="50" width="260" height="90" as="geometry" />
        </mxCell>

        <mxCell id="comp-refresh" value="&lt;b&gt;RefreshToken&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Use Case]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Rotação de refresh token&lt;br&gt;com re-emissão de acesso" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-app">
          <mxGeometry x="20" y="160" width="260" height="90" as="geometry" />
        </mxCell>

        <mxCell id="comp-validate" value="&lt;b&gt;ValidateToken&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Use Case]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Verifica assinatura, expiração&lt;br&gt;e revogação do token" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-app">
          <mxGeometry x="20" y="270" width="260" height="90" as="geometry" />
        </mxCell>

        <mxCell id="comp-revoke" value="&lt;b&gt;RevokeToken&lt;/b&gt;&lt;br&gt;&lt;i&gt;[Use Case]&lt;/i&gt;&lt;br&gt;&lt;br&gt;Revoga token individual&lt;br&gt;ou todos tokens do usuário" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#85BBF0;strokeColor=#5D82B5;fontSize=10;" vertex="1" parent="layer-app">
          <mxGeometry x="20" y="380" width="260" height="90" as="geometry" />
        </mxCell>

        <!-- Layer: Infrastructure Adapters -->
